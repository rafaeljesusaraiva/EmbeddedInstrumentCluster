{
    "cmake.preferredGenerators": ["Ninja"],
    "cmake.defaultVariants": {
        "buildType": {
            "default": "debug",
            "choices": {
                "debug":   { "short": "Debug",   "buildType": "Debug"      },
                "release": { "short": "Release", "buildType": "MinSizeRel" }
            }
        }
    },
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
    "files.associations": {
        "*.h":   "cpp",
        "*.cpp": "cpp"
    }
}